# RightCare environment variables — copy to .env and fill in.
# Get these from the Supabase dashboard → Project Settings → API.

# ── App (shipped in the bundle; safe because they're protected by RLS) ──
# Anything prefixed EXPO_PUBLIC_ is readable inside the app.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Local scripts only — NEVER prefix with EXPO_PUBLIC_, never ship this ──
# The service_role key bypasses row-level security. Used by scripts/ to
# read consults back and to simulate the phone call creating one.
SUPABASE_SERVICE_ROLE_KEY=
