{
  "expo": {
    "name": "Historia",
    "slug": "historia",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "historia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.historia.preconsultation"
    },
    "android": {
      "package": "com.historia.preconsultation"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "Historia uses your microphone so you can describe your symptoms by voice instead of typing."
        }
      ]
    ]
  }
}
